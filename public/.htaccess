# SPA (React Router): rotas diretas precisam cair no index.html
# Coloque este arquivo na pasta publicada (ex.: projetos/contaweb/) junto com index.html.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /projetos/contaweb/
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>
